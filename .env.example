# Firebase Configuration
# These values are usually auto-populated by the Firebase setup tool into firebase-applet-config.json
# but you can use them as env vars if needed.
FIREBASE_PROJECT_ID=tonjam-16d8f
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# AI Features (Gemini API)
GEMINI_API_KEY=

# Pinata IPFS (Optional for NFT minting)
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# Spotify OAuth (Optional for Artist Verification)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Twitter OAuth (Optional for Artist Verification)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=

# Instagram OAuth (Optional for Artist Verification)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=

# Vercel SSO (Optional)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=

# App Base URL
APP_URL=

# Firebase Admin (Optional - for server-side verification)
# This should be a base64 encoded JSON string of your service account key
FIREBASE_SERVICE_ACCOUNT_KEY=

# TON Blockchain Configuration
VITE_TON_NETWORK=testnet
