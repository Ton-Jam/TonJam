# ============================================
# FIREBASE CONFIGURATION (REQUIRED)
# ============================================
# Get these values from: Firebase Console → Project Settings → General
# These values are usually auto-populated by the Firebase setup tool into firebase-applet-config.json
FIREBASE_PROJECT_ID=tonjam-16d8f
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin Service Account Key (for server-side operations)
# Get from: Firebase Console → Project Settings → Service Accounts
# Option 1: Path to JSON file
FIREBASE_SERVICE_ACCOUNT_KEY=path/to/serviceAccountKey.json
# Option 2: Base64 encoded JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON=base64_encoded_json

# ============================================
# AUTHENTICATION & EXTERNAL SERVICES
# ============================================
# AI Features (Gemini API)
GEMINI_API_KEY=

# Pinata IPFS (Optional for NFT minting)
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=

# Spotify OAuth (Optional for Artist Verification)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Vercel SSO (Optional)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
VERCEL_REDIRECT_URI=

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# App Base URL
APP_URL=http://localhost:3000

# TON Blockchain Configuration
VITE_TON_NETWORK=testnet

# ============================================
# NOTES
# ============================================
# For detailed setup instructions, see: docs/firebase-setup.md
# Security Rules are in: firestore.rules and storage.rules
# Real-time hooks are in: src/hooks/ (useUserListener, usePresence, useActivity)
# API service is in: src/services/apiService.ts
