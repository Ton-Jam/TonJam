rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper function to get the user ID
    function userID() {
      return request.auth.uid;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return userID() == userId;
    }

    // Helper function to check file size
    function isValidSize(maxSize) {
      return request.resource.size <= maxSize;
    }

    // Helper function to validate file type
    function isValidImageType() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidAudioType() {
      return request.resource.contentType.matches('audio/.*');
    }

    function isValidDocumentType() {
      return request.resource.contentType.matches('application/(pdf|json|xml|.*ms-word.*|.*spreadsheet.*)');
    }

    // User avatars - users can upload/delete their own avatars
    match /users/{userId}/avatar/{allPaths=**} {
      allow read: if true; // Public read access for avatars
      allow create: if isAuth() && isOwner(userId) && isValidImageType() && isValidSize(5 * 1024 * 1024); // Max 5MB
      allow update: if isAuth() && isOwner(userId) && isValidImageType() && isValidSize(5 * 1024 * 1024);
      allow delete: if isAuth() && isOwner(userId);
    }

    // User profile banners
    match /users/{userId}/banner/{allPaths=**} {
      allow read: if true; // Public read access for banners
      allow create: if isAuth() && isOwner(userId) && isValidImageType() && isValidSize(10 * 1024 * 1024); // Max 10MB
      allow update: if isAuth() && isOwner(userId) && isValidImageType() && isValidSize(10 * 1024 * 1024);
      allow delete: if isAuth() && isOwner(userId);
    }

    // Artist/Creator music tracks
    match /tracks/{userId}/{trackId}/{allPaths=**} {
      allow read: if true; // Public read access to tracks
      allow create: if isAuth() && isOwner(userId) && (isValidAudioType() || isValidImageType()) && isValidSize(100 * 1024 * 1024); // Max 100MB for audio
      allow update: if isAuth() && isOwner(userId);
      allow delete: if isAuth() && isOwner(userId);
    }

    // NFT/Art asset storage
    match /nfts/{userId}/{nftId}/{allPaths=**} {
      allow read: if true; // Public read access
      allow create: if isAuth() && isOwner(userId) && (isValidImageType() || isValidAudioType() || isValidDocumentType()) && isValidSize(50 * 1024 * 1024); // Max 50MB
      allow update: if isAuth() && isOwner(userId);
      allow delete: if isAuth() && isOwner(userId);
    }

    // Temporary uploads - for processing before storage
    match /temp/{userId}/{allPaths=**} {
      allow create: if isAuth() && isOwner(userId) && isValidSize(100 * 1024 * 1024);
      allow read: if isAuth() && isOwner(userId);
      allow delete: if isAuth() && isOwner(userId);
    }

    // Public assets - promotional images, covers
    match /public/{allPaths=**} {
      allow read: if true; // Public read access
      allow create: if isAuth(); // Only authenticated users can upload
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
