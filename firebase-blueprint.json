{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "walletAddress": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "artist", "admin"] }
      },
      "required": ["uid", "name", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial or platform transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "recipientAddress": { "type": "string" },
        "senderAddress": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "type", "amount", "recipientAddress", "timestamp", "status"]
    },
    "Track": {
      "title": "Track",
      "description": "Music track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artistId": { "type": "string" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" }
      },
      "required": ["id", "title", "artistId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tracks/{trackId}": {
      "schema": "Track",
      "description": "Music tracks"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history"
    }
  }
}
