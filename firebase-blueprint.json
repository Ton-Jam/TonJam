{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "walletAddress": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "artist", "admin"] },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "isVerifiedArtist": { "type": "boolean" },
        "verificationStatus": { "type": "string", "enum": ["unverified", "pending", "verified"] },
        "xp": { "type": "number" },
        "collectorTier": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Platinum", "Legend"] },
        "badges": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "ArtistVerificationRequest": {
      "title": "ArtistVerificationRequest",
      "description": "Request for artist verification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "artistName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "bio": { "type": "string" },
        "statement": { "type": "string", "description": "Brief artist statement" },
        "socialLinks": { "type": "object" },
        "portfolioUrls": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewerNotes": { "type": "string" }
      },
      "required": ["id", "userId", "artistName", "status", "submittedAt"]
    },
    "Track": {
      "title": "Track",
      "description": "Music track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artistId": { "type": "string" },
        "creator": { "type": "string" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "genre": { "type": "string" },
        "playCount": { "type": "number" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "artistId"]
    },
    "NFT": {
      "title": "NFT",
      "description": "Sonic artifact",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artistId": { "type": "string" },
        "creator": { "type": "string" },
        "trackId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "string" },
        "edition": { "type": "string" },
        "editionType": { "type": "string" },
        "rarity": { "type": "string" },
        "supply": { "type": "number" },
        "listingType": { "type": "string" },
        "owner": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number" }
      },
      "required": ["id", "title", "artistId", "trackId"]
    },
    "Post": {
      "title": "Post",
      "description": "Social post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "content"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial or platform transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "recipientAddress": { "type": "string" },
        "senderAddress": { "type": "string" },
        "participants": { "type": "array" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "amount", "status"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "User created music playlist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "creator": { "type": "string" },
        "tracks": { "type": "array" },
        "description": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "coverUrl": { "type": "string" },
        "folderId": { "type": "string" }
      }
    },
    "PlaylistFolder": {
      "title": "PlaylistFolder",
      "description": "User created folder for organizing playlists",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "creator": { "type": "string" },
        "playlistIds": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Community": {
      "title": "Community",
      "description": "Artist fan community",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "artistId": { "type": "string" },
        "memberCount": { "type": "number" }
      }
    },
    "Follow": {
      "title": "Follow",
      "description": "User follow relationship",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Direct message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Like": {
      "title": "Like",
      "description": "User like on content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "targetId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TaskCompletion": {
      "title": "TaskCompletion",
      "description": "Record of a user completing a task",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "completed": { "type": "boolean" },
        "claimedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Proposal": {
      "title": "Proposal",
      "description": "Governance proposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "passed", "rejected", "executed"] },
        "category": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "forVotes": { "type": "number" },
        "againstVotes": { "type": "number" },
        "voters": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "creatorId", "title", "description", "status"]
    },
    "Vote": {
      "title": "Vote",
      "description": "User vote on a proposal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "proposalId": { "type": "string" },
        "userId": { "type": "string" },
        "choice": { "type": "string", "enum": ["for", "against"] },
        "power": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "proposalId", "userId", "choice"]
    },
    "TreasuryStats": {
      "title": "TreasuryStats",
      "description": "DAO Treasury statistics",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "totalFeesCollected": { "type": "number" },
        "totalGrantsAllocated": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "GrantAllocation": {
      "title": "GrantAllocation",
      "description": "Record of funds distributed from treasury",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "proposalId": { "type": "string" },
        "recipientId": { "type": "string" },
        "recipientName": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "JamRoomMessage": {
      "title": "JamRoomMessage",
      "description": "Message in a live JamSpace room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "content", "timestamp"]
    },
    "ArtistEvent": {
      "title": "ArtistEvent",
      "description": "Upcoming artist event or concert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "artistId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "venue": { "type": "string" },
        "location": { "type": "string" },
        "ticketUrl": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "artistId", "title", "date", "venue"]
    },
    "Listing": {
      "title": "Listing",
      "description": "NFT Marketplace listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nftId": { "type": "string" },
        "sellerId": { "type": "string" },
        "price": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "cancelled"] },
        "buyerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nftId", "sellerId", "price", "status"]
    },
    "Validator": {
      "title": "Validator",
      "description": "Network Validator node",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "apr": { "type": "number" },
        "uptime": { "type": "number" },
        "blocksValidated": { "type": "string" },
        "currentCommission": { "type": "string" },
        "commissionHistory": { "type": "array" },
        "selfStake": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "name", "apr", "uptime"]
    },
    "DailyMission": {
      "title": "DailyMission",
      "description": "Daily engagement task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "xpReward": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["id", "title", "xpReward", "date"]
    },
    "UserMissionProgress": {
      "title": "UserMissionProgress",
      "description": "User progress on a daily mission",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "missionId": { "type": "string" },
        "completed": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "missionId", "completed"]
    },
    "Offer": {
      "title": "Offer",
      "description": "Custom price offer for an NFT",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nftId": { "type": "string" },
        "offerer": { "type": "string" },
        "price": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nftId", "offerer", "price", "status", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "User report for inappropriate content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nftId": { "type": "string" },
        "reporterId": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nftId", "reporterId", "reason", "status", "createdAt"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Content reports"
    },
    "/offers/{offerId}": {
      "schema": "Offer",
      "description": "NFT buy offers"
    },
    "/validators/{validatorId}": {
      "schema": "Validator",
      "description": "Staking network validators"
    },
    "/dailyMissions/{missionId}": {
      "schema": "DailyMission",
      "description": "Daily missions"
    },
    "/userMissionProgress/{trackingId}": {
      "schema": "UserMissionProgress",
      "description": "User mission completion tracking"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Marketplace listings"
    },
    "/events/{eventId}": {
      "schema": "ArtistEvent",
      "description": "Artist events and tours"
    },
    "/system/treasury": {
      "schema": "TreasuryStats",
      "description": "DAO Treasury state"
    },
    "/grantAllocations/{id}": {
      "schema": "GrantAllocation",
      "description": "History of grant distributions"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tracks/{trackId}": {
      "schema": "Track",
      "description": "Music tracks"
    },
    "/nfts/{nftId}": {
      "schema": "NFT",
      "description": "Sonic artifacts"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social feed"
    },
    "/tracks/{trackId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes on a track"
    },
    "/tracks/{trackId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a track"
    },
    "/users/{userId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes on an artist/user profile"
    },
    "/users/{userId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on an artist/user profile"
    },
    "/posts/{postId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes on a post"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Global comments collection"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Platform transactions"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User playlists"
    },
    "/playlistFolders/{folderId}": {
      "schema": "PlaylistFolder",
      "description": "User playlist folders"
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Artist communities"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships"
    },
    "/jamRooms/{roomId}/messages/{messageId}": {
      "schema": "JamRoomMessage",
      "description": "Messages in a specific JamSpace room"
    },
    "/taskCompletions/{id}": {
      "schema": "TaskCompletion",
      "description": "Task completions"
    },
    "/verificationRequests/{requestId}": {
      "schema": "ArtistVerificationRequest",
      "description": "Artist verification requests"
    },
    "/proposals/{id}": {
      "schema": "Proposal",
      "description": "Governance proposals"
    },
    "/proposals/{id}/votes/{voteId}": {
      "schema": "Vote",
      "description": "Votes for a proposal"
    }
  }
}
