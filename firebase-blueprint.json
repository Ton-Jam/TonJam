{
  "entities": {
    "Track": {
      "title": "Track",
      "description": "A music track artifact",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "artistId": { "type": "string" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "duration": { "type": "number" },
        "genre": { "type": "string" },
        "isNFT": { "type": "boolean" },
        "price": { "type": "string" },
        "bpm": { "type": "number" },
        "key": { "type": "string" },
        "playCount": { "type": "number" },
        "likes": { "type": "number" },
        "releaseDate": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "title", "artist", "artistId", "coverUrl", "audioUrl", "genre", "isNFT"]
    },
    "NFTItem": {
      "title": "NFTItem",
      "description": "A music NFT artifact",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trackId": { "type": "string" },
        "title": { "type": "string" },
        "owner": { "type": "string" },
        "creator": { "type": "string" },
        "artist": { "type": "string" },
        "artistId": { "type": "string" },
        "price": { "type": "string" },
        "imageUrl": { "type": "string" },
        "edition": { "type": "string" },
        "supply": { "type": "number" },
        "minted": { "type": "number" },
        "isAuction": { "type": "boolean" },
        "description": { "type": "string" },
        "listingType": { "type": "string" }
      },
      "required": ["id", "trackId", "title", "owner", "creator", "price", "imageUrl", "edition"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "avatar": { "type": "string" },
        "walletAddress": { "type": "string" },
        "isVerifiedArtist": { "type": "boolean" },
        "jamBalance": { "type": "number" },
        "stakedJam": { "type": "number" },
        "pendingJamRewards": { "type": "number" },
        "likedTrackIds": { "type": "array", "items": { "type": "string" } },
        "followedUserIds": { "type": "array", "items": { "type": "string" } },
        "followers": { "type": "number" },
        "following": { "type": "number" },
        "earnings": { "type": "number" },
        "streamingEarnings": { "type": "number" },
        "nftEarnings": { "type": "number" },
        "royaltyConfig": {
          "type": "object",
          "properties": {
            "streamingSplits": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "address": { "type": "string" },
                  "percentage": { "type": "number" },
                  "label": { "type": "string" }
                }
              }
            },
            "nftSaleSplits": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "address": { "type": "string" },
                  "percentage": { "type": "number" },
                  "label": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "required": ["id", "name", "handle", "avatar"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A blockchain transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "string" },
        "recipientAddress": { "type": "string" },
        "senderAddress": { "type": "string" },
        "timestamp": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "type", "amount", "recipientAddress", "timestamp", "status"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "A user-created playlist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "coverUrl": { "type": "string" },
        "trackCount": { "type": "number" },
        "creator": { "type": "string" },
        "description": { "type": "string" },
        "trackIds": { "type": "array", "items": { "type": "string" } },
        "isPrivate": { "type": "boolean" },
        "isCollaborative": { "type": "boolean" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "title", "creator"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userHandle": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "trackId": { "type": "string" },
        "nftId": { "type": "string" },
        "likes": { "type": "number" },
        "reposts": { "type": "number" },
        "comments": { "type": "number" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "content", "timestamp"]
    }
  },
  "firestore": {
    "/tracks/{trackId}": {
      "schema": "Track",
      "description": "Global marketplace tracks"
    },
    "/nfts/{nftId}": {
      "schema": "NFTItem",
      "description": "Global marketplace NFTs"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User playlists"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social feed posts"
    }
  }
}
