{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information, roles, balances, and social data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth ID" },
        "username": { "type": "string", "description": "User handle" },
        "avatar": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "bannerUrl": { "type": "string", "format": "uri", "description": "Profile banner URL" },
        "bio": { "type": "string", "description": "Artist or collector biography" },
        "location": { "type": "string", "description": "Artist location" },
        "walletAddress": { "type": "string", "description": "TON wallet address" },
        "role": { "type": "string", "enum": ["artist", "collector", "admin"], "description": "User role" },
        "followers": { "type": "integer", "description": "Number of followers" },
        "following": { "type": "integer", "description": "Number of following" },
        "earnings": { "type": "number", "description": "Total earnings" },
        "name": { "type": "string", "description": "Display name" },
        "earningsBreakdown": {
          "type": "object",
          "properties": {
            "streaming": { "type": "number" },
            "nft": { "type": "number" },
            "tips": { "type": "number" },
            "sponsorship": { "type": "number" }
          }
        },
        "isVerifiedArtist": { "type": "boolean", "description": "Artist verification status" },
        "socials": {
          "type": "object",
          "properties": {
            "x": { "type": "string" },
            "spotify": { "type": "string" },
            "instagram": { "type": "string" },
            "website": { "type": "string" },
            "telegram": { "type": "string" }
          }
        },
        "isPremium": { "type": "boolean", "description": "Premium subscription status" },
        "jamBalance": { "type": "number", "description": "JAM token balance" },
        "stakedJam": { "type": "number", "description": "Amount of JAM staked" },
        "pendingJamRewards": { "type": "number", "description": "Unclaimed JAM rewards" },
        "lastStakingUpdate": { "type": "string", "format": "date-time" },
        "followedArtists": { "type": "array", "items": { "type": "string" } },
        "followedUserIds": { "type": "array", "items": { "type": "string" } },
        "likedTrackIds": { "type": "array", "items": { "type": "string" } },
        "friends": { "type": "array", "items": { "type": "string" } },
        "favoriteGenres": { "type": "array", "items": { "type": "string" } },
        "transactions": { "type": "array", "items": { "$ref": "Transaction" } },
        "createdPlaylistIds": { "type": "array", "items": { "type": "string" } },
        "ownedNftIds": { "type": "array", "items": { "type": "string" } },
        "listedNftIds": { "type": "array", "items": { "type": "string" } },
        "anthemId": { "type": "string", "description": "ID of the user's anthem track" },
        "royaltyConfig": {
          "type": "object",
          "properties": {
            "defaultSplitPercentage": { "type": "number" },
            "payoutAddress": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "username", "role"]
    },
    "Track": {
      "title": "Music Track",
      "description": "Metadata for music tracks uploaded by artists.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique track ID" },
        "title": { "type": "string", "description": "Track title" },
        "artist": { "type": "string" },
        "artistId": { "type": "string", "description": "UID of the artist" },
        "coverUrl": { "type": "string", "format": "uri", "description": "Cover art URL" },
        "audioUrl": { "type": "string", "format": "uri", "description": "Audio file URL" },
        "duration": { "type": "integer" },
        "genres": { "type": "array", "items": { "type": "string" }, "description": "Music genres" },
        "moods": { "type": "array", "items": { "type": "string" }, "description": "Track moods" },
        "language": { "type": "string", "description": "Track language" },
        "isNFT": { "type": "boolean", "description": "Whether the track is an NFT" },
        "artistVerified": { "type": "boolean" },
        "price": { "type": "string", "description": "Base price in TON" },
        "streamingPrice": { "type": "string" },
        "editions": { "type": "string" },
        "minted": { "type": "integer", "description": "Number of editions minted" },
        "editionType": { "type": "string" },
        "rarity": { "type": "string" },
        "royaltyPercentage": { "type": "number", "description": "Royalty percentage" },
        "metadataUrl": { "type": "string", "description": "IPFS metadata URL" },
        "bpm": { "type": "integer", "description": "Beats per minute" },
        "key": { "type": "string", "description": "Musical key" },
        "bitrate": { "type": "string" },
        "playCount": { "type": "integer" },
        "streams": { "type": "integer" },
        "likes": { "type": "integer" },
        "jamScore": { "type": "number" },
        "releaseDate": { "type": "string", "format": "date-time" },
        "ipfsUrl": { "type": "string" },
        "cid": { "type": "string" },
        "description": { "type": "string" },
        "audioIpfsUrl": { "type": "string" },
        "coverIpfsUrl": { "type": "string" },
        "royaltySplits": { "type": "array", "items": { "$ref": "RoyaltySplit" } },
        "lyrics": { "type": "string" },
        "isCollaboration": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" }
      },
      "required": ["id", "title", "artistId", "artist", "audioUrl"]
    },
    "NFT": {
      "title": "Music NFT",
      "description": "Represents a minted music NFT.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique NFT ID" },
        "trackId": { "type": "string", "description": "Source track ID" },
        "title": { "type": "string", "description": "NFT title" },
        "owner": { "type": "string" },
        "creator": { "type": "string" },
        "artist": { "type": "string" },
        "artistId": { "type": "string" },
        "price": { "type": "string", "description": "Current listing price in TON" },
        "imageUrl": { "type": "string", "format": "uri", "description": "NFT image URL" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "edition": { "type": "string", "description": "NFT edition type" },
        "supply": { "type": "integer" },
        "minted": { "type": "integer" },
        "isAuction": { "type": "boolean" },
        "contractAddress": { "type": "string" },
        "royaltySplits": { "type": "array", "items": { "$ref": "RoyaltySplit" } },
        "stems_available": { "type": "boolean" },
        "description": { "type": "string" },
        "traits": { "type": "array", "items": { "$ref": "NFTTrait" } },
        "attributes": { "type": "array", "items": { "$ref": "NFTTrait" } },
        "history": { "type": "array", "items": { "$ref": "NFTHistory" } },
        "offers": { "type": "array", "items": { "$ref": "NFTOffer" } },
        "exclusiveContent": { "type": "array", "items": { "$ref": "ExclusiveContent" } },
        "ipfsUrl": { "type": "string" },
        "cid": { "type": "string" },
        "listingType": { "type": "string", "enum": ["fixed", "auction"] },
        "auctionStartTime": { "type": "string" },
        "auctionEndTime": { "type": "string" },
        "startingBid": { "type": "string" },
        "royalty": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Minting timestamp" }
      },
      "required": ["id", "trackId", "title", "owner", "price"]
    },
    "Post": {
      "title": "Social Signal",
      "description": "Social feed posts (signals) from artists.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "username": { "type": "string", "description": "User handle" },
        "userAvatar": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "content": { "type": "string", "description": "Post content" },
        "imageUrl": { "type": "string", "format": "uri", "description": "Optional image URL" },
        "video": { "type": "string" },
        "trackId": { "type": "string" },
        "nftId": { "type": "string" },
        "likes": { "type": "integer", "description": "Number of likes" },
        "isLiked": { "type": "boolean" },
        "reposts": { "type": "integer" },
        "isReposted": { "type": "boolean" },
        "comments": { "type": "integer", "description": "Number of comments" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Post timestamp" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "createdAt": { "type": "string" },
        "artistId": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "type": { "type": "string" },
        "paymentAmount": { "type": "string" },
        "paymentCurrency": { "type": "string" },
        "status": { "type": "string" },
        "artistName": { "type": "string" },
        "link": { "type": "string" },
        "targetId": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "content"]
    },
    "Like": {
      "title": "Post Like",
      "description": "Records a like on a post.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique like ID" },
        "postId": { "type": "string", "description": "Target post ID" },
        "userId": { "type": "string", "description": "UID of the user who liked" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Like timestamp" }
      },
      "required": ["id", "postId", "userId"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "Records a comment on a post.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique comment ID" },
        "userId": { "type": "string", "description": "UID of the commenter" },
        "userName": { "type": "string", "description": "Name of the commenter" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string", "description": "Comment content" },
        "timestamp": { "type": "string" },
        "likes": { "type": "integer" },
        "reactions": { "type": "object" },
        "userReactions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time", "description": "Comment timestamp" }
      },
      "required": ["id", "userId", "content"]
    },
    "Follow": {
      "title": "User Follow",
      "description": "Records a follow relationship.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique follow ID" },
        "followerId": { "type": "string", "description": "UID of the follower" },
        "followingId": { "type": "string", "description": "UID of the followed user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Follow timestamp" }
      },
      "required": ["id", "followerId", "followingId"]
    },
    "Bid": {
      "title": "NFT Bid",
      "description": "A bid placed on an NFT listing.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique bid ID" },
        "nftId": { "type": "string", "description": "Target NFT ID" },
        "bidderId": { "type": "string", "description": "UID of the bidder" },
        "bidderName": { "type": "string", "description": "Name of the bidder" },
        "amount": { "type": "string", "description": "Bid amount in TON" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Bid timestamp" }
      },
      "required": ["id", "nftId", "bidderId", "amount"]
    },
    "Royalty": {
      "title": "Artist Royalty",
      "description": "Financial records for artist earnings.",
      "type": "object",
      "properties": {
        "artistId": { "type": "string", "description": "UID of the artist" },
        "totalEarned": { "type": "string", "description": "Total lifetime earnings in TON" },
        "pendingWithdrawal": { "type": "string", "description": "Earnings available for withdrawal" },
        "lastWithdrawal": { "type": "string", "format": "date-time", "description": "Last withdrawal timestamp" }
      },
      "required": ["artistId", "totalEarned", "pendingWithdrawal"]
    },
    "SongRequest": {
      "title": "Song Request",
      "description": "A request for a song from a fan to an artist.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "artistId": { "type": "string" },
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "songTitle": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "fulfilled", "rejected"] },
        "tipAmount": { "type": "string" },
        "hasTipped": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "artistId", "requesterId", "songTitle", "status"]
    },
    "SponsoredContent": {
      "title": "Sponsored Content",
      "description": "Promoted tracks or NFTs on the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "artistId": { "type": "string" },
        "artistName": { "type": "string" },
        "type": { "type": "string", "enum": ["track", "nft", "announcement"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetId": { "type": "string" },
        "link": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "expired"] },
        "paymentAmount": { "type": "string" },
        "paymentCurrency": { "type": "string", "enum": ["TON", "JAM"] },
        "durationDays": { "type": "integer" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "artistId", "type", "title", "status"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "A request to withdraw earnings from the platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "string" },
        "currency": { "type": "string", "enum": ["TON", "JAM"] },
        "recipientAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "timestamp": { "type": "string" },
        "txHash": { "type": "string" }
      },
      "required": ["id", "amount", "currency", "recipientAddress", "status"]
    },
    "Task": {
      "title": "User Task",
      "description": "Tasks or achievements for users to earn rewards.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "reward": { "type": "string" },
        "points": { "type": "integer" },
        "completed": { "type": "boolean" },
        "claimed": { "type": "boolean" },
        "type": { "type": "string", "enum": ["daily", "achievement", "milestone", "seasonal"] },
        "progress": { "type": "integer" },
        "total": { "type": "integer" },
        "dueDate": { "type": "string" },
        "rarity": { "type": "string", "enum": ["common", "rare", "epic", "legendary"] },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "link": { "type": "string", "description": "Optional task link" }
      },
      "required": ["id", "title", "type", "completed"]
    },
    "TaskCompletion": {
      "title": "Task Completion",
      "description": "Records when a user completes a task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "completed": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "taskId", "completed"]
    },
    "RoyaltySplit": {
      "type": "object",
      "properties": {
        "address": { "type": "string" },
        "percentage": { "type": "number" },
        "label": { "type": "string" }
      }
    },
    "NFTTrait": {
      "type": "object",
      "properties": {
        "trait_type": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "NFTHistory": {
      "type": "object",
      "properties": {
        "event": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "date": { "type": "string" },
        "price": { "type": "string" }
      }
    },
    "NFTOffer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "offerer": { "type": "string" },
        "price": { "type": "string" },
        "duration": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "ExclusiveContent": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "track", "image", "document"] },
        "url": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "NFTMint": {
      "title": "NFT Mint Record",
      "description": "Records of minted NFTs.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique mint ID" },
        "trackId": { "type": "string", "description": "ID of the track" },
        "ownerId": { "type": "string", "description": "UID of the owner" },
        "edition": { "type": "integer", "description": "Edition number" },
        "txHash": { "type": "string", "description": "Transaction hash" },
        "price": { "type": "number", "description": "Mint price" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Minting timestamp" }
      },
      "required": ["id", "trackId", "ownerId"]
    },
    "NFTCollection": {
      "title": "NFT Collection",
      "description": "Metadata for NFT collections.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "artistId": { "type": "string" },
        "contractAddress": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "artistId", "name"]
    },
    "NFTSale": {
      "title": "NFT Sale",
      "description": "Records of NFT sales.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nftId": { "type": "string" },
        "sellerId": { "type": "string" },
        "buyerId": { "type": "string" },
        "price": { "type": "number" },
        "royaltyPaid": { "type": "number" },
        "txHash": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nftId", "sellerId", "buyerId", "price"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/tracks/{trackId}": {
      "schema": "Track",
      "description": "Music track metadata."
    },
    "/nfts/{nftId}": {
      "schema": "NFT",
      "description": "Minted NFT documents."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social feed signals."
    },
    "/posts/{postId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes on a post."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a post."
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships."
    },
    "/nfts/{nftId}/bids/{bidId}": {
      "schema": "Bid",
      "description": "Bidding history for specific NFTs."
    },
    "/royalties/{artistId}": {
      "schema": "Royalty",
      "description": "Artist financial records."
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User created playlists."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Platform transaction logs."
    },
    "/songRequests/{requestId}": {
      "schema": "SongRequest",
      "description": "Song requests from fans to artists."
    },
    "/sponsoredContent/{contentId}": {
      "schema": "SponsoredContent",
      "description": "Promoted content on the platform."
    },
    "/withdrawalRequests/{requestId}": {
      "schema": "WithdrawalRequest",
      "description": "Withdrawal requests from users."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User specific tasks and achievements."
    },
    "/taskCompletions/{completionId}": {
      "schema": "TaskCompletion",
      "description": "Global log of task completions."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages between users."
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Exclusive fan communities."
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User subscriptions to communities."
    },
    "/nftMints/{mintId}": {
      "schema": "NFTMint",
      "description": "Records of minted NFTs."
    },
    "/nftCollections/{collectionId}": {
      "schema": "NFTCollection",
      "description": "NFT collection metadata."
    },
    "/nftSales/{saleId}": {
      "schema": "NFTSale",
      "description": "NFT sale records."
    },
    "/test/{docId}": {
      "schema": {
        "title": "Test Connection",
        "description": "Used to test Firestore connection.",
        "type": "object",
        "properties": {
          "status": { "type": "string" }
        }
      },
      "description": "Connection test collection."
    }
  }
}
