{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "artist", "admin"] }
      },
      "required": ["uid", "name", "email"]
    },
    "Track": {
      "title": "Track",
      "description": "Music track",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artistId": { "type": "string" },
        "coverUrl": { "type": "string" },
        "audioUrl": { "type": "string" }
      },
      "required": ["id", "title", "artistId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/tracks/{trackId}": {
      "schema": "Track",
      "description": "Music tracks"
    }
  }
}
