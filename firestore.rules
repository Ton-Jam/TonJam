rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "krusherkrupy@gmail.com" && request.auth.token.email_verified == true));
    }

    function getWalletAddress(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.get('walletAddress', '');
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
    match /tracks/{trackId} {
      allow read: if true;
      // TODO: Harden write access to artist-only
      allow write: if isAuthenticated();
    }
    match /nfts/{nftId} {
      allow read: if true;
      // TODO: Harden write access to owner-only
      allow write: if isAuthenticated();
    }
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /comments/{commentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /reactions/{reactionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /playlists/{playlistId} {
      allow read: if true;
      // TODO: Harden write access to creator-only
      allow write: if isAuthenticated();
    }
    match /sponsoredContent/{contentId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /posts/{postId} {
      allow read: if true;
      // TODO: Harden write access to author-only
      allow write: if isAuthenticated();
      
      match /comments/{commentId} {
        allow read: if true;
        allow write: if isAuthenticated();
      }
      
      match /likes/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }
    match /songRequests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /fanEngagement/{engagementId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.amount is number && 
               data.type is string && 
               data.status in ['pending', 'completed', 'failed'] &&
               data.get('recipientAddress', '') is string && data.get('recipientAddress', '').size() < 100 &&
               (!('senderAddress' in data) || (data.senderAddress is string && data.senderAddress.size() < 100)) &&
               (!('trackTitle' in data) || (data.trackTitle is string && data.trackTitle.size() < 200)) &&
               (!('txHash' in data) || (data.txHash is string && data.txHash.size() < 200));
      }

      function isTransactionOwner(data) {
        let wallet = getWalletAddress(request.auth.uid);
        let participants = data.get('participants', []);
        return request.auth.uid in participants ||
               request.auth.uid == data.get('userId', '') ||
               request.auth.uid == data.get('senderAddress', '') || 
               request.auth.uid == data.get('recipientAddress', '') ||
               (wallet != '' && (wallet == data.get('senderAddress', '') || wallet == data.get('recipientAddress', '')));
      }

      allow read: if isAuthenticated() && isTransactionOwner(resource.data);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && isTransactionOwner(request.resource.data);
      allow update, delete: if false;
    }
    match /taskCompletions/{completionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow write: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /communities/{communityId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /artists/{artistId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /nftSales/{saleId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
