    return $RoyaltyParams$_to_external(res);
}

;;
;; Routing of a Contract TonJamCollection
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'next_item_index, $self'content, ($self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination)) = $TonJamCollection$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    var op = in_msg~load_opcode_internal();
    ;; Receive Mint message
    if (op == 2107022347) {
        var $msg'query_id = in_msg~load_uint(64);
        var $msg'receiver = in_msg~load_msg_addr();
        var $msg'content = in_msg~load_ref();
        var ($msg'royalty_params'numerator, $msg'royalty_params'denominator, $msg'royalty_params'destination) = in_msg~$RoyaltyParams$_load();
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        throw_unless(57579, ( equal_slices_bits($ctx'sender, $self'owner) ));
        var ($nft_init'code, $nft_init'data) = ($self'owner, $self'next_item_index, $self'content, ($self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination))~$TonJamCollection$_fun_getNftItemInit($self'next_item_index);
        $global_send($SendParameters$_constructor_to_value_bounce_mode_body_code_data($global_contractAddress(($nft_init'code, $nft_init'data)), 0, false, 64, $Builder$_fun_endCell($Builder$_fun_storeBit(false, $Builder$_fun_storeCoins($Builder$_fun_storeBit(false, $Builder$_fun_storeAddress($Builder$_fun_storeAddress(store_uint(store_uint($global_beginCell(), 1607220500, 32), $msg'query_id, 64), $msg'receiver), $self'owner)), 0))), $nft_init'code, $nft_init'data));
        $self'next_item_index = ($self'next_item_index + 1);
        $TonJamCollection$_contract_store(($self'owner, $self'next_item_index, $self'content, ($self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination)));
        return ();
    }
    
    ;; Receive GetRoyaltyParams message
    if (op == 0x693d3950) {
        var $msg'query_id = in_msg~load_uint(64);
        $global_send($SendParameters$_constructor_to_value_mode_body(__tact_context_get_sender(), 0, 64, $ReportRoyaltyParams$_store_cell($ReportRoyaltyParams$_constructor_query_id_numerator_denominator_destination($msg'query_id, $self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination), begin_cell())));
        $TonJamCollection$_contract_store(($self'owner, $self'next_item_index, $self'content, ($self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination)));
        return ();
    }
    
    ;; Receive Deploy message
    if (op == 0x946a98b6) {
        var $deploy'queryId = in_msg~load_uint(64);
        ($self'owner, $self'next_item_index, $self'content, ($self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination))~$TonJamCollection$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
        $TonJamCollection$_contract_store(($self'owner, $self'next_item_index, $self'content, ($self'royalty_params'numerator, $self'royalty_params'denominator, $self'royalty_params'destination)));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}
